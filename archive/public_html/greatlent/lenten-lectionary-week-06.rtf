\cs20\i\f1\cf6\insrsid3042872  
\par }{\cs19\f35\fs32\insrsid3042872\charrsid11692121 Ye are blessed of the Lord, Who made heaven and the earth.
\par 
\par }{\cs20\i\f1\cf6\insrsid3042872 Stichos: }{\cs19\f35\fs32\insrsid3042872\charrsid11692121  The heaven of heaven belongeth to the Lord, but the earth He gave unto the sons of men.
\par 
\par }\pard\plain \s24\qc \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0 \b\i\f1\fs32\cf6\lang1024\langfe1024\cgrid\noproof\langnp1033\langfenp1033 {\cs19\f35\insrsid3042872\charrsid11692121 \sect }\sectd 
