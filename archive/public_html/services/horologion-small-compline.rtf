\par 
\par IT SHOULD BE KNOWN: that from
\par {\listtext\pard\plain\ltrpar \s22 \rtlch\fcs1 \ab\ai\af3 \ltrch\fcs0 \cs28\f3\cf6\insrsid2049427 \loch\af3\dbch\af0\hich\f3 \'b7\tab}}\pard \ltrpar\s22\ql \fi-360\li720\ri0\widctlpar\jclisttab\tx720\wrapdefault\faauto\ls5\adjustright\rin0\lin720\itap0 {
