\par }\pard \ltrpar\s22\ql \li0\ri0\widctlpar\wrapdefault\faauto\adjustright\rin0\lin0\itap0 {\rtlch\fcs1 \ai\af1\afs24 \ltrch\fcs0 \cs28\i\fs24\cf6\insrsid2049427 
