\par 
\par But if there be
\par {\listtext\pard\plain\s22 \cs28\f3\cf6 \loch\af3\dbch\af0\hich\f3 \'b7\tab}}\pard \s22\ql \fi-360\li720\ri0\widctlpar\jclisttab\tx720\faauto\ls7\adjustright\rin0\lin720\itap0 {\cs28\i\fs24\cf6\insrsid6574074 a feast of the Theotokos, 
