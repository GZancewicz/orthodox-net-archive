\s37\qc \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0\pararsid148921 \b\i\f1\fs32\cf6\lang1024\langfe1024\cgrid\noproof\langnp1033\langfenp1033 {\insrsid148921 
