\par }\pard\plain \s57\qc \li0\ri0\widctlpar\faauto\adjustright\rin0\lin0\itap0\pararsid6953665 \b\i\f1\fs32\cf6\lang1024\langfe1024\cgrid\noproof\langnp1033\langfenp1033 {\insrsid7473308\charrsid6953665 
