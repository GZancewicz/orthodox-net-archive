\par }\pard \qj\sb100\sa100\nowidctlpar\adjustright {\cs43\b\i\f1\fs28 Deacon:}{\fs32  }{\cs47\b\fs36 For this city (or town, or holy monastery), every city and country and the faithful that dwell therein, let us pray to the Lord.}{\fs32  
