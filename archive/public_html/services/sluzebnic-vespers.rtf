\par }\pard \qj\sb100\sa100\nowidctlpar\adjustright {\cs43\b\i\f1\fs28 Deacon:}{\fs32  }{\cs47\b\fs36 For the precious Gifts set forth, let us pray to the Lord.}{\fs32  
