\par }\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid8348719 
\par }{\cs28\i\f1\cf6\insrsid8348719 After the full beginning, Ps. 142, "O Lord hear my prayer".
\par }{\insrsid8348719 
\par }{\cs28\i\f1\cf6\insrsid8348719 Great Litany with special Petitions as above.}{\insrsid8348719 
\par 
\par }{\cs28\i\f1\cf6\insrsid8348719 Before the Troparia, insert "God is the Lord", T. 8.}{\insrsid8348719 
\par 
\par }{\cs28\i\f1\cf6\insrsid8348719 After the Litany of Fervent Supplication with the special Petition as above, read the Prayer from the Proscomide, substituting "this Prayer" for "this Sacrifice", and with the concluding Doxology, "For Thine it is."
\par }{\insrsid8348719 
