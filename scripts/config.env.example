# orthodox.net server connection details
# Copy this file to config.env and fill in your credentials:
#   cp config.env.example config.env
#
# NEVER commit config.env to git (it's in .gitignore)

# SSH connection
SSH_HOST=orthodox.net
SSH_USER=your_cpanel_username
SSH_PORT=22

# Remote path to the website root
REMOTE_PATH=/home/${SSH_USER}/public_html

# Local path where downloaded content will be stored
LOCAL_PATH=../public_html
